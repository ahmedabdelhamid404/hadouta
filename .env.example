# Hadouta Umbrella — Operations Credentials Template
# Copy this file to `.env.local` (which is gitignored) and fill in real values.
# Used by scripts in `scripts/observability/` for direct Sentry + PostHog REST API access.
#
# Why this exists: Claude Code's HTTP-MCP OAuth implementation has a bug
# (anthropics/claude-code#12077) that prevents the standard `/mcp` browser-flow
# auth from working with Sentry and PostHog MCPs. The bearer-token alternative
# also has issues (Sentry's MCP gateway is a separate auth realm from their
# REST API). So we bypass MCP entirely for now and hit REST APIs directly via
# the helper scripts in scripts/observability/.

# ----- Sentry (https://sentry.io) -----
# Create at: https://sentry.io/settings/account/api/auth-tokens/
# Required scopes for our scripts: org:read, project:read, event:read, team:read
# Token format: starts with `sntryu_` (user auth token) or `sntrys_` (org token)
SENTRY_AUTH_TOKEN=
SENTRY_ORG_SLUG=                  # find at https://sentry.io/settings/<org>/

# ----- PostHog (eu.posthog.com — Hadouta is on the EU instance) -----
# Create at: https://eu.posthog.com/settings/user-api-keys
# Token format: starts with `phx_`
POSTHOG_PERSONAL_API_KEY=
POSTHOG_HOST=https://eu.posthog.com   # EU instance — DO NOT change to us.posthog.com (that returns 401)
POSTHOG_PROJECT_ID=                   # find at https://eu.posthog.com/settings/project (top of page)

# ----- Cloudinary (photo storage for the order wizard, Phase 5 Task 1.9) -----
# Why Cloudinary instead of Cloudflare R2: no credit card required for free tier.
# Free tier: 25 GB storage + 25 GB bandwidth/month — well past Hadouta MVP scale.
# Bonus: auto image transformations (thumbnails, HEIC→JPEG, format conversion,
# CDN delivery) handled by Cloudinary — saves backend code.
# https://cloudinary.com/pricing
#
# How to get these:
#   1. Sign up at https://cloudinary.com/users/register_free
#      (email + password — NO credit card required)
#   2. Dashboard → top section "Programmable Media" → "Account Details" or
#      "Go to API Keys" → reveals:
#         - Cloud name (also visible in dashboard URL)
#         - API Key (~15 numeric chars)
#         - API Secret (click "reveal" — ~27 alphanumeric chars)
#   3. (Recommended) Settings → Security → enable "Restricted media types"
#      to prevent abuse of free quota for non-image uploads
#
# All three values below are required for the backend to upload + serve photos.
CLOUDINARY_CLOUD_NAME=         # short string visible in dashboard URL
CLOUDINARY_API_KEY=            # ~15 numeric chars
CLOUDINARY_API_SECRET=         # ~27 alphanumeric chars — click "reveal" in dashboard

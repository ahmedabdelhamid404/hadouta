# Hadouta Umbrella — Operations Credentials Template
# Copy this file to `.env.local` (which is gitignored) and fill in real values.
# Used by scripts in `scripts/observability/` for direct Sentry + PostHog REST API access.
#
# Why this exists: Claude Code's HTTP-MCP OAuth implementation has a bug
# (anthropics/claude-code#12077) that prevents the standard `/mcp` browser-flow
# auth from working with Sentry and PostHog MCPs. The bearer-token alternative
# also has issues (Sentry's MCP gateway is a separate auth realm from their
# REST API). So we bypass MCP entirely for now and hit REST APIs directly via
# the helper scripts in scripts/observability/.

# ----- Sentry (https://sentry.io) -----
# Create at: https://sentry.io/settings/account/api/auth-tokens/
# Required scopes for our scripts: org:read, project:read, event:read, team:read
# Token format: starts with `sntryu_` (user auth token) or `sntrys_` (org token)
SENTRY_AUTH_TOKEN=
SENTRY_ORG_SLUG=                  # find at https://sentry.io/settings/<org>/

# ----- PostHog (eu.posthog.com — Hadouta is on the EU instance) -----
# Create at: https://eu.posthog.com/settings/user-api-keys
# Token format: starts with `phx_`
POSTHOG_PERSONAL_API_KEY=
POSTHOG_HOST=https://eu.posthog.com   # EU instance — DO NOT change to us.posthog.com (that returns 401)
POSTHOG_PROJECT_ID=                   # find at https://eu.posthog.com/settings/project (top of page)

# ----- Cloudflare R2 (photo storage for the order wizard, Phase 5 Task 1.9) -----
# Free tier: 10 GB storage + 1M Class A ops + 10M Class B ops per month, egress free.
# https://developers.cloudflare.com/r2/pricing/
#
# How to get these:
#   1. Sign up / sign in at https://dash.cloudflare.com (no payment method needed for free tier)
#   2. Left sidebar → "R2 Object Storage" → "Create bucket" with name "hadouta-photos"
#      (use "Automatic" location; eastern hemisphere is fine for Egyptian users)
#   3. R2 Overview page → top-right copy icon next to "Account ID" → paste below
#   4. Sidebar → "Manage R2 API Tokens" → "Create API token"
#      - Token name: "hadouta-backend"
#      - Permissions: "Object Read & Write"
#      - Specify bucket: "hadouta-photos" (don't grant access to all buckets)
#      - TTL: leave blank (no expiry) OR pick 1 year
#      - Click "Create" → copy "Access Key ID" + "Secret Access Key" + "S3 endpoint"
#   5. Optional but recommended — set up public access for serving uploaded photos:
#      - Bucket settings → "Public access" → enable "Custom Domains" or "r2.dev subdomain"
#      - r2.dev subdomain is FREE and instant (e.g., pub-<id>.r2.dev) — use that for MVP
#      - Custom domain (photos.hadouta.com) requires DNS — defer to Track B
#
# All five values below are required for the backend to upload + serve photos.
R2_ACCOUNT_ID=                # 32-char hex string from R2 Overview page
R2_ACCESS_KEY_ID=             # ~32 chars; from "Manage R2 API Tokens"
R2_SECRET_ACCESS_KEY=         # 64+ chars; ONLY shown once at creation — save carefully
R2_BUCKET_NAME=hadouta-photos # the bucket you created in step 2 above
R2_PUBLIC_URL=                # e.g., https://pub-abc123.r2.dev — from step 5 (r2.dev subdomain)
                              # OR https://photos.hadouta.com once custom domain is wired (Track B)
